# Base URL of the backend REST API.
# Point this at your real backend when ready; the app currently runs
# against stubbed/mock responses defined in src/api/mockAdapter.js.
VITE_API_BASE_URL=https://api.your-domain.com/v1

# Set to "true" to force the app to use the mock adapter even if a
# backend is reachable. Useful for demos / offline development.
VITE_USE_MOCK_API=true
